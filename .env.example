# Deployer (required for Ledger signing, auto-derived for --account)
DEPLOYER_ADDRESS=

# Governance owner (required; set to Safe/multisig for production)
OWNER_ADDRESS=

# Deterministic deployment salt inputs
# Must be a non-zero bytes32 value (example format: 0x + 64 hex chars)
DEPLOYMENT_SALT_SECRET=
# Optional namespace tag for parallel deterministic deployments (for example: v2, staging)
SALT_TAG=

# RPC URLs (set the one for your target network)
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
OP_SEPOLIA_RPC_URL=
MAINNET_RPC_URL=
BASE_RPC_URL=

# ERC-8004 dependencies (must have code deployed)
IDENTITY_REGISTRY=
VALIDATION_REGISTRY=
SETTLEMENT_TOKEN=

# ReputationScorer params
# You can use SCORER_PRIOR_VALUE (preferred) or SCORER_PRIOR_VALUE_WEI fallback.
SCORER_PRIOR_VALUE=
SCORER_PRIOR_VALUE_WEI=
SCORER_SLASH_MULTIPLIER_BPS=10000

# AgentBondManager params
DISPUTE_PERIOD=604800
MIN_PASSING_SCORE=50
SLASH_BPS=5000
VALIDATION_FINALITY_POLICY=0
STATUS_LOOKUP_FAILURE_POLICY=0

# Optional overrides (normally read from deployments artifact)
MANAGER_PROXY=
SCORER_PROXY=
NEW_IMPLEMENTATION=
